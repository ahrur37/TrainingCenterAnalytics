<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:TCA.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TCA.Desktop.Views.RegistrationView"
             x:DataType="vm:RegistrationViewModel">

    <ScrollViewer Background="#F0F2F5" VerticalScrollBarVisibility="Auto">
        <Border Classes="card" Width="360" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,24">
            <StackPanel Spacing="20">

                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <Border Background="#66BB6A" CornerRadius="12" Width="48" Height="48"
                            HorizontalAlignment="Center">
                        <TextBlock Text="✏️" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Регистрация" FontSize="22" FontWeight="Bold"
                               Foreground="#212121" HorizontalAlignment="Center"/>
                    <TextBlock Text="Создайте новый аккаунт" FontSize="13"
                               Foreground="#757575" HorizontalAlignment="Center"/>
                </StackPanel>

                <Separator/>

                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Имя"/>
                        <TextBox Text="{Binding Name}" PlaceholderText="Введите имя"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Email"/>
                        <TextBox Text="{Binding Email}" PlaceholderText="Введите email"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Пароль"/>
                        <TextBox Text="{Binding Password}" PasswordChar="•" PlaceholderText="Введите пароль"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="{Binding Message}" Foreground="{Binding MessageColor}" FontSize="13"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <StackPanel Spacing="8">
                    <Button Classes="primary" Content="Зарегистрироваться"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding RegistrationCommand}"/>
                    <Button Classes="ghost" Content="← Назад"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding GoBackCommand}"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </ScrollViewer>

</UserControl>
