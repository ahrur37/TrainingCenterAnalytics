<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:TCA.Desktop.ViewModels"
             x:DataType="vm:LobbyViewModel"
             x:Class="TCA.Desktop.Views.LobbyView">
    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, *">
        <StackPanel Orientation="Horizontal" Spacing="30" Margin="10" Grid.ColumnSpan="2">
            <Button Content="Log out" Command="{Binding LogoutCommand}"/>
            <Button Content="Create request" Command="{Binding GoToCreateRequestCommand}"/>
            <ComboBox ItemsSource="{Binding Listdirections}" IsVisible="{Binding CanView}" SelectedItem="{Binding SelectedDirection, Mode=TwoWay}" DisplayMemberBinding="{Binding Name}" Width="150"/>
            <ComboBox ItemsSource="{Binding Liststatuses}" IsVisible="{Binding CanView}" SelectedItem="{Binding SelectedStatus, Mode=TwoWay}" DisplayMemberBinding="{Binding Name}" Width="150"/>
            <Button Content="Reset" Command="{Binding ResetFiltersCommand}" IsVisible="{Binding CanView}"/>
            <Button Content="Manuals" Command="{Binding GoToManualsCommand}" IsVisible="{Binding CanViewAdm}" HorizontalAlignment="Right"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Requests}" SelectedItem="{Binding SelectedRequest, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" Grid.Row="1" Grid.Column="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№"           Binding="{Binding Id}"                  Width="50" />
                <DataGridTextColumn Header="Тема"        Binding="{Binding Topic}"                Width="200" />
                <DataGridTextColumn Header="Описание"    Binding="{Binding Description}"          Width="250" />
                <DataGridTextColumn Header="Направление" Binding="{Binding Direction.Name}"       Width="150" />
                <DataGridTextColumn Header="Формат"      Binding="{Binding TrainingFormat.Name}"  Width="120" />
                <DataGridTextColumn Header="Статус"      Binding="{Binding Status.Name}"          Width="120" />
                <DataGridTextColumn Header="Создана"     Binding="{Binding CreatedAt}"            Width="130" />
                <DataGridTextColumn Header="Менеджер"    Binding="{Binding Assignee.Name}"        Width="130" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Grid.Column="1" Width="300" Margin="10" Spacing="10">
            <StackPanel IsVisible="{Binding CanView}" Spacing="10">
                <TextBlock Text="Статус заявки" FontWeight="Bold"/>
                <ComboBox ItemsSource="{Binding Liststatuses}"
                          SelectedItem="{Binding SelectedNewStatus, Mode=TwoWay}"
                          DisplayMemberBinding="{Binding Name}"
                          Width="280"/>
                <Button Content="Изменить статус" Command="{Binding ChangeStatusCommand}" HorizontalAlignment="Stretch"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding MessageColor}"/>
            </StackPanel>
            
            <Separator IsVisible="{Binding CanView}"/>

            <TextBlock Text="Комментарии" FontWeight="Bold"/>
            <ListBox ItemsSource="{Binding Listcomments}" Height="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Author.Name}" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CreatedAt}" FontSize="11" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <TextBox Text="{Binding NewComment, Mode=TwoWay}" Watermark="Введите комментарий..." Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
            <Button Content="Отправить" Command="{Binding AddCommentCommand}" HorizontalAlignment="Stretch"/>
            <TextBlock Text="{Binding ShareStatusMessage}" Foreground="{Binding ShareMessageColor}"/>
        </StackPanel>
    </Grid>
</UserControl>
