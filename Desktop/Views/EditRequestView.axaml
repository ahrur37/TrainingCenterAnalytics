<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:TCA.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="560"
             x:Class="TCA.Desktop.Views.EditRequestView"
             x:DataType="vm:EditRequestViewModel">

    <Grid RowDefinitions="Auto, *" Background="#F0F2F5">

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BoxShadow="0 1 4 0 #14000000" Padding="24,14">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Background="#5C6BC0" CornerRadius="8" Width="34" Height="34">
                        <TextBlock Text="✏️" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Редактирование заявки" FontSize="17" FontWeight="SemiBold"
                               Foreground="#212121" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="2" Classes="ghost" Content="← Назад"
                        Command="{Binding GoBackCommand}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <Border Classes="card" Width="480" HorizontalAlignment="Center">
                <StackPanel Spacing="16">

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Тема *"/>
                        <TextBox Text="{Binding Topic, Mode=TwoWay}" PlaceholderText="Введите тему заявки"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Описание"/>
                        <TextBox Text="{Binding Description, Mode=TwoWay}"
                                 PlaceholderText="Введите описание"
                                 Height="90"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Контактная информация"/>
                        <TextBox Text="{Binding ContactInfo, Mode=TwoWay}" PlaceholderText="Телефон или email"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Направление *"/>
                        <ComboBox ItemsSource="{Binding Directions}"
                                  SelectedItem="{Binding SelectedDirection, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Формат обучения *"/>
                        <ComboBox ItemsSource="{Binding Formats}"
                                  SelectedItem="{Binding SelectedFormat, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <TextBlock Text="{Binding Message}"
                               Foreground="{Binding MessageColor}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <Button Classes="primary" Content="Сохранить изменения"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding SaveCommand}"/>

                    <Button Classes="danger" Content="Удалить заявку"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding DeleteCommand}"/>

                </StackPanel>
            </Border>
        </ScrollViewer>

    </Grid>

</UserControl>
