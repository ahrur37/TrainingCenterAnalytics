<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:TCA.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="560"
             x:Class="TCA.Desktop.Views.CreateRequestView"
             x:DataType="vm:CreateRequestViewModel">

    <Grid RowDefinitions="Auto, *" Background="#F0F2F5">

        <Border Grid.Row="0" Background="White" BoxShadow="0 1 4 0 #14000000" Padding="24,14">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <Button Classes="ghost" Content="← Назад" Command="{Binding GoBackCommand}" VerticalAlignment="Center"/>
                <TextBlock Text="Новая заявка" FontSize="20" FontWeight="SemiBold"
                           Foreground="#212121" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="24">
            <Border Classes="card" Width="480" HorizontalAlignment="Center">
                <StackPanel Spacing="16">

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Тема *"/>
                        <TextBox Text="{Binding Topic, Mode=TwoWay}" Watermark="Введите тему заявки"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Описание"/>
                        <TextBox Text="{Binding Description, Mode=TwoWay}"
                                 Watermark="Введите описание"
                                 Height="90"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Контактная информация"/>
                        <TextBox Text="{Binding ContactInfo, Mode=TwoWay}" Watermark="Телефон или email"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Направление *"/>
                        <ComboBox ItemsSource="{Binding Directions}"
                                  SelectedItem="{Binding SelectedDirection, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="label" Text="Формат обучения *"/>
                        <ComboBox ItemsSource="{Binding Formats}"
                                  SelectedItem="{Binding SelectedFormat, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{Binding ErrorMessageColor}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <Button Classes="primary" Content="Создать заявку"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding CreateRequestCommand}"/>

                </StackPanel>
            </Border>
        </ScrollViewer>

    </Grid>

</UserControl>
